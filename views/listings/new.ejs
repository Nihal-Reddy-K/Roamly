<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
    <br>
    <h3 class="mb-4">Create a New Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" placeholder="add a title" type="text" class="form-control" required>
            <div class="valid-feedback">Title is good to go!</div>
        </div>

        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" placeholder="enter description" type="text" class="form-control" required></textarea>
            <div class="invalid-feedback">Enter a brief description!</div>
        </div>

        <div class="mb-3">
            <label for="image" class="form-label">Upload Image</label>
            <input name="listing[image]" type="file" class="form-control" required>
        </div>
        
        <div class="row">

            <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]" placeholder="eg: 2000" type="number" min="0" class="form-control" required>
            <div class="invalid-feedback">Enter a valid pricing!</div>
            </div>

            <div class="mb-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" placeholder="eg: India" type="text" class="form-control" required>
            <div class="invalid-feedback">Enter a valid country name!</div>
            </div>

        </div>

        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" placeholder="eg: Bengaluru, Karnataka" type="text" class="form-control" required>
            <div class="invalid-feedback">Enter the location!</div>
        </div>

        <div class="mb-3">
            <label for="category" class="form-label">Category</label>
            <select name="listing[category]" id="category" class="form-select" required>
                <option value="Trending">Trending</option>
                <option value="Beach">Beach</option>
                <option value="Mountains">Mountains</option>
                <option value="City">City</option>
                <option value="Camping">Camping</option>
                <option value="Luxury">Luxury</option>
                <option value="Farms">Farms</option>
                <option value="Arctic">Arctic</option>
                <option value="Desert">Desert</option>
                <option value="Pool">Pool</option>
            </select>
        </div>
   
        <button class="btn btn-primary add-btn mt-3">Add Listing</button>
    </form>
    </div>
</div>
